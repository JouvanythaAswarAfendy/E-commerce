{
    "version": 2,
    "framework": null,
    "buildCommand": "npm install && npm run build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "VERCEL": "1",
        "LOG_CHANNEL": "stderr",
        "LOG_LEVEL": "error",
        "SESSION_DRIVER": "cookie",
        "CACHE_STORE": "array",
        "VIEW_COMPILED_PATH": "/tmp/storage/framework/views"
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/images/(.*)",
            "dest": "/public/images/$1"
        },
        {
            "src": "/css/(.*)",
            "dest": "/public/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/public/js/$1"
        },
        {
            "src": "/fonts/(.*)",
            "dest": "/public/fonts/$1"
        },
        {
            "src": "/favicon\\.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots\\.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}